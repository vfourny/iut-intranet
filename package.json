{
  "name": "iut-intranet",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo watch dev",
    "preview": "turbo preview",
    "ts:check": "turbo ts:check",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix --",
    "format": "turbo build --filter=@iut-intranet/configs && prettier --write .",
    "format:check": "turbo build --filter=@iut-intranet/configs && prettier --check .",
    "db:start": "docker compose -f docker/local.compose.yml up -d",
    "db:down": "docker compose -f docker/local.compose.yml down",
    "db:generate": "turbo db:generate --filter=@iut-intranet/db",
    "db:migrate": "turbo db:migrate --filter=@iut-intranet/db",
    "db:deploy": "turbo db:deploy --filter=@iut-intranet/db",
    "db:seed": "turbo db:seed --filter=@iut-intranet/db",
    "db:reset": "turbo db:reset --filter=@iut-intranet/db",
    "db:push": "turbo db:push --filter=@iut-intranet/db",
    "db:studio": "turbo db:studio --filter=@iut-intranet/db",
    "clean": "turbo clean && rimraf node_modules .turbo",
    "prepare": "husky",
    "syncpack:check": "syncpack lint --dependency-types dev,prod"
  },
  "engines": {
    "node": "22.22.2"
  },
  "packageManager": "npm@10.9.7",
  "devDependencies": {
    "@iut-intranet/configs": "*",
    "@types/node": "22.19.15",
    "eslint": "9.39.4",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "syncpack": "14.3.1",
    "tsc-alias": "1.8.16",
    "tsx": "4.21.0",
    "turbo": "2.8.21",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2"
  },
  "commitlint": {
    "extends": [
      "@iut-intranet/configs/commitlint"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "npm run lint:fix"
    ],
    "*": [
      "prettier --write --ignore-unknown"
    ]
  },
  "prettier": "@iut-intranet/configs/prettier"
}
