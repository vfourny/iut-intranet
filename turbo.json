{
  "$schema": "https://turborepo.com/schema.json",
  "concurrency": "15",
  "ui": "tui",
  "tasks": {
    "build": {
      "cache": true,
      "outputs": ["dist/**"],
      "dependsOn": ["db:generate", "^db:generate", "^build"]
    },
    "preview": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "db:generate": {
      "cache": true,
      "outputs": ["**/generated/**"],
      "dependsOn": ["^build"]
    },
    "db:migrate": {
      "cache": false
    },
    "db:deploy": {
      "cache": false
    },
    "db:seed": {
      "cache": false,
      "dependsOn": ["db:generate"]
    },
    "db:reset": {
      "cache": false,
      "dependsOn": ["db:generate"]
    },
    "db:push": {
      "cache": false
    },
    "provider:seed": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "cache": true,
      "dependsOn": ["db:generate", "^build"]
    },
    "lint:fix": {
      "cache": false,
      "dependsOn": ["db:generate", "^build"]
    },
    "ts:check": {
      "cache": true,
      "dependsOn": ["db:generate", "^db:generate", "^build"]
    },
    "//#test": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": [
        "packages/*/src/**",
        "packages/*/tests/**",
        "packages/*/vitest.config.*",
        "vitest.config.*"
      ],
      "outputs": ["coverage/**"]
    },
    "//#test:watch": {
      "cache": false,
      "dependsOn": ["^build"],
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "cron:archive-news": {
      "cache": false,
      "dependsOn": ["^build"]
    }
  },
  "globalEnv": [
    "NODE_ENV",
    "ADMIN_EMAIL",
    "ADMIN_PASSWORD",
    "DATABASE_URL",
    "API_PORT",
    "PUBLIC_API_URL",
    "APP_PORT",
    "PUBLIC_APP_URL",
    "RESEND_API_KEY",
    "EMAIL_FROM",
    "BETTER_AUTH_SECRET",
    "S3_ACCESS_KEY_ID",
    "S3_BUCKET",
    "S3_ENDPOINT",
    "S3_REGION",
    "S3_SECRET_ACCESS_KEY",
    "CRON_SECRET"
  ],
  "globalDependencies": [
    ".nvmrc",
    ".npmrc",
    ".syncpackrc.json",
    "tsconfig.json"
  ]
}
