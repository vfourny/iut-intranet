{
  "dependencies": {
    "@trpc/server": "11.8.1",
    "zod": "4.1.5"
  },
  "devDependencies": {
    "@iut-intranet/configs": "*"
  },
  "exports": {
    "./env": {
      "source": "./src/env.ts",
      "types": "./dist/env.d.ts",
      "default": "./dist/env.js"
    },
    "./errors": {
      "source": "./src/errors.ts",
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    }
  },
  "name": "@iut-intranet/helpers",
  "private": true,
  "scripts": {
    "build": "tsc && tsc-alias",
    "clean": "rimraf node_modules dist .turbo",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "ts:check": "tsc --noEmit"
  },
  "type": "module",
  "version": "0.0.1"
}
