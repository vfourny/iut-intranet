{
  "dependencies": {
    "@vfourny/node-toolkit": "1.1.15",
    "pino": "10.3.1",
    "pino-http": "11.0.0"
  },
  "devDependencies": {
    "@commitlint/types": "20.5.0",
    "pino-pretty": "13.1.3"
  },
  "exports": {
    "./commitlint": {
      "types": "./dist/commitlint.config.d.ts",
      "default": "./dist/commitlint.config.js"
    },
    "./eslint/*": {
      "types": "./dist/eslint/*.d.ts",
      "default": "./dist/eslint/*.js"
    },
    "./logger": {
      "source": "./src/logger.ts",
      "types": "./dist/logger.d.ts",
      "default": "./dist/logger.js"
    },
    "./prettier": {
      "types": "./dist/prettier.config.d.ts",
      "default": "./dist/prettier.config.js"
    },
    "./tsconfig/*": "./dist/tsconfig/*.json"
  },
  "name": "@iut-intranet/configs",
  "private": true,
  "scripts": {
    "build": "tsc && tsc-alias",
    "clean": "rimraf node_modules dist .turbo",
    "dev": "run-p dev:tsc dev:alias",
    "dev:alias": "tsc-alias --watch",
    "dev:tsc": "tsc --watch --preserveWatchOutput",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "ts:check": "tsc --noEmit"
  },
  "type": "module",
  "version": "0.0.1"
}
