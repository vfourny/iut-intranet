{
  "dependencies": {
    "@iut-intranet/db": "*",
    "@iut-intranet/emails": "*",
    "@iut-intranet/helpers": "*",
    "argon2": "0.44.0",
    "better-auth": "1.4.10"
  },
  "devDependencies": {
    "@iut-intranet/configs": "*"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "source": "./src/types.ts",
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "name": "@iut-intranet/auth",
  "private": true,
  "scripts": {
    "build": "tsc && tsc-alias",
    "clean": "rimraf node_modules dist .turbo",
    "dev": "run-p dev:tsc dev:alias",
    "dev:alias": "tsc-alias --watch",
    "dev:tsc": "tsc --watch --preserveWatchOutput",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "ts:check": "tsc --noEmit"
  },
  "type": "module",
  "version": "0.0.1"
}
