<div style="max-width: 650px; margin: 0 auto; background-color: #f8f9fa; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; color: #333333; padding: 20px 10px; border-top: 2px solid #e0e0e0;">
  
  <div style="text-align: center; font-size: 14px; font-weight: bold; color: #111111; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 20px;">
    {{footer.organization}}
  </div>

  <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 10px;">
    
    <div style="flex: 1; text-align: center; font-size: 11px; line-height: 1.4;">
      <strong style="color: #0056b3; font-size: 12px; display: block; margin-bottom: 4px;">{{footer.site.boulogne.name}}</strong>
      <div style="color: #666666; margin-bottom: 2px;">{{footer.site.boulogne.location}}</div>
      <a href="tel:{{footer.site.boulogne.tel}}" style="color: #444444; text-decoration: none;">{{footer.site.boulogne.tel}}</a>
    </div>

    <div style="flex: 1; text-align: center; font-size: 11px; line-height: 1.4;">
      <strong style="color: #0056b3; font-size: 12px; display: block; margin-bottom: 4px;">{{footer.site.calais.name}}</strong>
      <div style="color: #666666; margin-bottom: 2px;">{{footer.site.calais.location}}</div>
      <a href="tel:{{footer.site.calais.tel}}" style="color: #444444; text-decoration: none;">{{footer.site.calais.tel}}</a>
    </div>

    <div style="flex: 1; text-align: center; font-size: 11px; line-height: 1.4;">
      <strong style="color: #0056b3; font-size: 12px; display: block; margin-bottom: 4px;">{{footer.site.dunkerque.name}}</strong>
      <div style="color: #666666; margin-bottom: 2px;">{{footer.site.dunkerque.location}}</div>
      <a href="tel:{{footer.site.dunkerque.tel}}" style="color: #444444; text-decoration: none;">{{footer.site.dunkerque.tel}}</a>
    </div>

    <div style="flex: 1; text-align: center; font-size: 11px; line-height: 1.4;">
      <strong style="color: #0056b3; font-size: 12px; display: block; margin-bottom: 4px;">{{footer.site.stOmer.name}}</strong>
      <div style="color: #666666; margin-bottom: 2px;">{{footer.site.stOmer.location}}</div>
      <a href="tel:{{footer.site.stOmer.tel}}" style="color: #444444; text-decoration: none;">{{footer.site.stOmer.tel}}</a>
    </div>

  </div>
</div>