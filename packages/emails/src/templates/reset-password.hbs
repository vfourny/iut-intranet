{{> header}}

<div>
    {{{t.greeting}}} {{user.firstName}} {{user.lastName}},
</div>

<div>
    <p>{{{t.intro}}}</p>
    <p>{{{t.instruction}}}</p>
</div>

<div>
    <a href="{{resetPasswordUrl}}">
        {{{t.cta}}}
    </a>
</div>

<div>
    <p>
        <strong>{{{t.expiryNotice}}} {{expiresIn}}.</strong>
    </p>

    <p style="margin-top: 15px; font-size: 14px; color: #666;">
        {{{t.securityNotice}}}
    </p>

    <p style="margin-top: 15px; font-size: 14px; color: #666;">
        {{{t.singleUseNotice}}}
    </p>
</div>

<div>
    <p>
        {{{t.fallbackInstruction}}}
    </p>
    <p>
        {{resetPasswordUrl}}
    </p>
</div>

{{> footer}}
