enum Site {
  BOULOGNE
  CALAIS
  DUNKERQUE
  SAINT_OMER
}

enum DepartmentCode {
  GACO
  GEA
  TC
  INFO
  GEII
  GIM
  GB
  MT2E
  Administration
  Technique
}

model Department {
  id   String         @id @default(cuid())
  code DepartmentCode @unique
  site Site

  events         Event[] @relation("EventDepartments")
  targetedByNews News[]
  users  UserDepartment[]

  @@map("department")
}
