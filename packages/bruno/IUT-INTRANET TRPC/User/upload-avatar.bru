meta {
  name: Upload avatar
  type: http
  seq: 4
}

post {
  url: {{SERVER_URL}}/{{TRPC}}/user.uploadMyAvatar
  body: json
  auth: inherit
}

body:json {
  {
    "base64": "{{avatarBase64}}",
    "contentType": "image/png"
  }
}

vars:pre-request {
  avatarBase64: iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==
}

settings {
  encodeUrl: true
  timeout: 0
}
