meta {
  name: Get Event By Id
  type: http
  seq: 1
}

get {
  url: {{SERVER_URL}}/{{TRPC}}/event.getById?input={"eventId":"{{activeEventId}}"}
  body: none
  auth: inherit
}

params:query {
  input: {"eventId":"{{activeEventId}}"}
}

vars:pre-request {
  activeEventId: cmp3qak28000e20oiu9n6opqc
  SERVER_URL: http://localhost:8000
  TRPC: trpc
}

settings {
  encodeUrl: true
  timeout: 0
}
