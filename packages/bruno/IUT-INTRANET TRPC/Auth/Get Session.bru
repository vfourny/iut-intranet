meta {
  name: Get Session
  type: http
  seq: 6
}

get {
  url: {{SERVER_URL}}/{{TRPC}}/auth.getSession
  body: none
  auth: inherit
}

headers {
  Content-Type: application/json
}

script:post-response {
  const body = res.getBody()
  const user = body?.result?.data?.user
  if (user) {
    bru.setVar('activeUserId', user.id)
    bru.setVar('activeUserEmail', user.email)
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
