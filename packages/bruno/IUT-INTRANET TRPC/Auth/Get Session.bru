meta {
  name: Get Session
  type: http
  seq: 5
}

get {
  url: {{SERVER_URL}}/{{TRPC}}/auth.getSession
  body: none
  auth: inherit
}

headers {
  Content-Type: application/json
}

script:post-response {
  const session = res.getBody()
  const user = session.result.data.user
  bru.setVar('activeUserId', user.id)
  bru.setVar('activeUserEmail',user.email)
  
}

settings {
  encodeUrl: true
  timeout: 0
}
