meta {
  name: Forgot Password
  type: http
  seq: 8
}

post {
  url: {{SERVER_URL}}/{{TRPC}}/auth.forgotPassword
  body: json
  auth: inherit
}

body:json {
  {
      "email": "{{activeUserEmail}}"
  }
}

script:pre-request {
  const environment = bru.getEnvName();
  
  if (environment === 'localhost') {
    const defaultEmail = bru.getCollectionVar('resendDeliveredEmail');
    req.setBody({
      email:defaultEmail
    })
  } 
}

settings {
  encodeUrl: true
  timeout: 0
}
